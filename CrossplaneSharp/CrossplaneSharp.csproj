<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>

        <!-- NuGet package metadata -->
        <PackageId>CrossplaneSharp</PackageId>
        <Version>1.0.0</Version>
        <Authors>IhorPetr</Authors>
        <Description>C# implementation of the Python crossplane NGINX config parser/lexer/builder</Description>
        <PackageTags>nginx;crossplane;config;parser;lexer;builder</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/IhorPetr/CrossplaneSharp</RepositoryUrl>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <!-- Suppress XML-doc and style warnings that are not errors -->
        <NoWarn>1591;CS1591;IDE0044;IDE0060;IDE0130</NoWarn>
    </PropertyGroup>

</Project>
